#Exposure classifications
#female
library(dplyr)
  data <- data %>%
  mutate(
    BP_f_classification = case_when( 
      bp_self_report_f ==1 | sbp_level_f>=140 | dbp_level_f >= 90 ~ "hbp",
      sbp_level_f >=120 & sbp_level_f<140 | dbp_level_f>=80 & dbp_level_f < 90 ~ "ebp",
      sbp_level_f < 120 & dbp_level_f < 80 ~ "normal",
      TRUE ~ NA_character_
    ),
    BP_f_classification = factor(BP_f_classification, levels = c("normal","ebp","hbp"))
  )
#male
data <- data %>%
  mutate(
    BP_m_classification = case_when( 
      bp_self_report_m ==1 | sbp_level_m>=140 | dbp_level_m >= 90 ~ "hbp",
      sbp_level_m >=120 & sbp_level_m<140 | dbp_level_m>=80 & dbp_level_m < 90 ~ "ebp",
      sbp_level_m < 120 & dbp_level_m < 80 ~ "normal",
      TRUE ~ NA_character_
    ),
    BP_m_classification = factor(BP_m_classification, levels = c("normal","ebp","hbp"))
  )
#outcome definition  
#PTB
data <- data %>%  
  mutate(
  PTB = case_when(
Gestational_age < 37 & Gestational_age > 28 ~ 1, 
Gestational_age >= 37 ~ 0,
TRUE ~ NA_real_
    ))
#LBW/Macrosomia
data$macrosomia <- ifelse(data$Fetus_baby_weight > 4000, 1,
                          ifelse(data$Fetus_baby_weight <= 4000, 0, NA))

data$LBW <- ifelse(data$Fetus_baby_weight < 2500, 1,
                          ifelse(data$Fetus_baby_weight >= 2500, 0, NA))
#SGA/LGA
library(data.table) 
setDT(data) 
ref_table <- data[, .(
  P10 = quantile(Fetus_baby_weight, 0.10, na.rm = TRUE),
  P90 = quantile(Fetus_baby_weight, 0.90, na.rm = TRUE)
), by = .(Fetus_baby_sex, Gestational_age)]

data[ref_table, on = c("Fetus_baby_sex", "Gestational_age"), `:=`(
  P10 = i.P10,
  P90 = i.P90
)]
data[, `:=`(
  SGA = as.integer(Fetus_baby_weight < P10),
  LGA = as.integer(Fetus_baby_weight > P90)
)] 

#composite adverse birth outcomes
data$com_apo <- ifelse(
  data$PTB == 1 | 
    data$medically_induced_abortion == 1 | 
    data$natrual_pre == 1 | 
    data$LBW == 1 | 
    data$macrosomia == 1 | 
    data$SGA == 1 | 
    data$LGA == 1 |
    data$birth_defects == 1 | 
    data$PID == 1, 1, 
  ifelse(
    data$PTB == 0 & 
      data$medically_induced_abortion == 0 & 
      data$natrual_pre == 0 & 
      data$LBW == 0 & 
      data$macrosomia == 0 & 
      data$SGA == 0 & 
      data$LGA == 0 &
      data$birth_defects == 0 & 
      data$PID == 0, 0, NA
  )
)

