#p for interaction
library(lmtest)
model_main <- speedglm(
  outcome ~ BP_m_classification+BP_f_classification+maternal_age+paternal_age+maternal_bmi+paternal_bmi
               +maternal_smoking+maternal_drinking+paternal_smoking+paternal_drinking
               +maternal_ethnicity+maternal_use_medicine+maternal_education+maternal_residence+maternal_economic_pressure+region
               +paternal_ethnicity+paternal_use_medicine+paternal_education+paternal_residence+paternal_economic_pressure
               +harmful_exposures+history_apo+parity+diabetes,
  family = poisson(link = "log"),
  data = data
)
model_interaction <- speedglm(
  outcome ~ BP_m_classification*BP_f_classification+maternal_age+paternal_age+maternal_bmi+paternal_bmi
               +maternal_smoking+maternal_drinking+paternal_smoking+paternal_drinking
               +maternal_ethnicity+maternal_use_medicine+maternal_education+maternal_residence+maternal_economic_pressure+region
               +paternal_ethnicity+paternal_use_medicine+paternal_education+paternal_residence+paternal_economic_pressure
               +harmful_exposures+history_apo+parity+diabetes,
  family = poisson(link = "log"),
  data = data
)
lrtest_result <- lrtest(model_main, model_interaction)
interaction_p <- lrtest_result[2, "Pr(>Chisq)"]
summary(model_interaction)
