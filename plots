library(dplyr)
library(ggplot2)
maternal_stacked <- data.frame(
  Outcome = rep(c("Spontaneous abortion", "Medically induced abortion", 
                  "Preterm birth", "Perinatal death", "Small for gestational age",
                  "Large for gestational age", "Low birth weight", "Macrosomia",
                  "Birth defects", "Composite adverse birth outcomes"), each = 2),
  BP_Type = rep(c("Elevated BP", "Hypertension"), 10),
  PAF = c(1.77, 0.74, 3.47, 1.22, 1.52, 0.63, 1.77, 1.22, 
          -0.52, 0.33, 3.23, 0.36, 3.47, 2.01, 3.95, 0.66,
          NA, 0.47, 1.52, 0.43),
  Parent = "Mother"
)

paternal_stacked <- data.frame(
  Outcome = rep(c("Spontaneous abortion", "Medically induced abortion", 
                  "Preterm birth", "Perinatal death", "Small for gestational age",
                  "Large for gestational age", "Low birth weight", "Macrosomia",
                  "Birth defects", "Composite adverse birth outcomes"), each = 2),
  BP_Type = rep(c("Elevated BP", "Hypertension"), 10),
  PAF = c(NA, 1.56, 6.23, 3.25, 2.97, 0.76, NA, 0.90,
          -5.38, 0.34, 8.85, 1.28, 0.50, 2.62, 7.99, 2.07,
          NA, 1.70, 2.00, 0.86),
  Parent = "Father"
)
combined_stacked <- rbind(maternal_stacked, paternal_stacked)
combined_stacked$PAF_stack <- combined_stacked$PAF
combined_stacked$PAF_stack[!is.na(combined_stacked$PAF_stack) & combined_stacked$PAF_stack < 0] <- 0

outcome_labels <- c(
  "Spontaneous abortion" = "natrual_pre",
  "Medically induced abortion" = "Medically_induced_abortion",
  "Preterm birth" = "PTB",
  "Perinatal death" = "PID",
  "Small for gestational age" = "SGA",
  "Large for gestational age" = "LGA",
  "Low birth weight" = "LBW",
  "Macrosomia" = "macrosomia",
  "Birth defects" = "birth_defects",
  "Composite adverse birth outcomes" = "com_apo"
)

combined_stacked$Outcome_short <- factor(combined_stacked$Outcome,
                                         levels = names(outcome_labels),
                                         labels = outcome_labels)

sum_data <- combined_stacked %>%
  group_by(Outcome_short, Parent) %>%
  summarise(Sum_PAF = sum(PAF[PAF > 0], na.rm = TRUE), .groups = "drop")

