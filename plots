#RCS curves
library(rms)
library(ggplot2)
library(speedglm)
library(dplyr)

dd <- datadist(data)
options(datadist = "dd")

map_range <- seq(50, 150, by = 1)
fit <- Glm(
  outcome ~ rcs(MAP_f, 3)   
    +maternal_age+paternal_age+maternal_bmi+paternal_bmi
               +maternal_smoking+maternal_drinking+paternal_smoking+paternal_drinking
               +maternal_ethnicity+maternal_use_medicine+maternal_education+maternal_residence+maternal_economic_pressure+region
               +paternal_ethnicity+paternal_use_medicine+paternal_education+paternal_residence+paternal_economic_pressure
               +harmful_exposures+history_apo+parity+diabetes+MAP_m,     #The mean arterial pressure（MAP） of spouses was mutually adjusted
  family = poisson(link = "log"),
  data = data
)
pred <- Predict(fit, MAP_f = map_range, 
                ref.zero = TRUE, fun = exp, conf.int = 0.95)
pred_df <- as.data.frame(pred)

anova_result <- anova(fit)
print(anova_result)
p_value_nonlinear <- anova_result["MAP_f", "P"]

pred_df <- pred_df %>% 
 filter(!is.na(yhat), !is.na(MAP_f)) %>% 
  arrange(MAP_f)

p <- ggplot(pred_df, aes(x = MAP_f, y = yhat)) +
  geom_ribbon(aes(ymin = lower, ymax = upper), fill = "lightpink", alpha = 0.5) +  
  geom_line(linewidth = 1.2, color = "red") +
  geom_hline(yintercept = 1, linetype = "dashed", color = "black", linewidth = 0.8) +
  labs(x = "Preconception MAP", y = "RR (95% CI)") +
  theme_minimal() +
  theme(
    panel.grid.major = element_blank(),
    panel.grid.minor = element_blank(),
    panel.border = element_blank(),
    axis.line.x = element_line(color = "black", linewidth = 0.5),
    axis.line.y = element_line(color = "black", linewidth = 0.5),
    axis.ticks = element_line(color = "black", linewidth = 0.5),
    axis.ticks.length = unit(0.2, "cm")
  )+
scale_x_continuous(
    breaks = seq(50, 150, by = 20),  
    limits = c(50, 150)               
  ) +coord_cartesian(ylim = c(1, 4)) +
  scale_y_continuous(
    breaks = seq(1, 4, by = 0.5) 
  )+
  
  annotate("text", 
           x = min(pred_df$MAP_f),
           y = 4,  
           label = "outcome",
           hjust = 0,
