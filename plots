library(ggplot2)
cor_test <- cor.test(data$MAP_f, data$MAP_m)
r <- cor_test$estimate
p_value <- cor_test$p.value
p_text <- ifelse(p_value < 0.001, "p < 0.001", paste("p =", round(p_value, 3)))

p <- ggplot(data, aes(x = MAP_f, y = MAP_m)) +
  geom_point(alpha = 0.3, size = 0.8, color = "steelblue") +
  geom_smooth(method = "lm", se = TRUE, color = "red") +
  annotate("text", x = Inf, y = -Inf, 
           label = paste("r =", round(r, 3), "\n", p_text), 
           hjust = 1.1, vjust = -0.5, size = 5) +
  labs(x = "Father's MAP (mm Hg)", y = "Mother's MAP (mm Hg)") +
  theme_minimal()

